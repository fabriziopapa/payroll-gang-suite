{
  "name": "payroll-gang-suite",
  "version": "26.4.11",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev":          "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build":        "npm run build --workspace=server && npm run build --workspace=client",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "db:migrate":   "npm run migrate --workspace=server",
    "db:seed":      "npm run seed --workspace=server",
    "typecheck":    "npm run typecheck --workspace=client && npm run typecheck --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
