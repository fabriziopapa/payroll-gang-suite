# ============================================================
# PAYROLL GANG SUITE — .env.example
# Copia questo file in .env e compila tutti i valori.
# MAI committare .env — contiene segreti di produzione.
# ============================================================

# ============================================================
# GENERAZIONE CHIAVI SICURE — riferimento rapido
# ============================================================
# Genera OGNI segreto in modo casuale: mai riusare esempi, password
# personali o valori "a mano". Ogni chiave deve essere unica per
# installazione. Di seguito i comandi (i dettagli sono ripetuti anche
# accanto a ciascuna variabile più sotto).
#
# --- Chiavi da GENERARE tu (con questi comandi) --------------
#
# 1) ENCRYPTION_KEY  e  COOKIE_SECRET  (32 byte → 64 hex)
#    Servono due valori DIVERSI: lancia il comando due volte.
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    In alternativa senza Node:
#      openssl rand -hex 32
#
# 2) CINECA_PROXY_SECRET  (solo se usi il proxy Italia; min 32 char)
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#    Deve coincidere col valore nel Caddy del proxy.
#
# 3) JWT — coppia di chiavi ES256 (ECDSA P-256), poi codificate base64:
#      openssl ecparam -genkey -name prime256v1 -noout | \
#        openssl pkcs8 -topk8 -nocrypt -out /tmp/jwt_priv.pem
#      openssl ec -in /tmp/jwt_priv.pem -pubout -out /tmp/jwt_pub.pem
#      echo "JWT_PRIVATE_KEY_BASE64=$(base64 -w 0 /tmp/jwt_priv.pem)"
#      echo "JWT_PUBLIC_KEY_BASE64=$(base64 -w 0 /tmp/jwt_pub.pem)"
#      rm /tmp/jwt_priv.pem /tmp/jwt_pub.pem
#    (macOS: base64 non ha -w 0 → usa `base64 /tmp/jwt_priv.pem | tr -d '\n'`)
#
# 4) DB_PASSWORD — scegline una robusta e casuale per l'utente Postgres:
#      openssl rand -base64 24
#
# --- Segreti forniti da TERZI (non generarli — ottienili così) ---
#   SMTP_PASS            → "app-specific password" dal pannello del provider
#                          email (iCloud/Gmail/…), non la password del login.
#   TURNSTILE_SECRET_KEY → da dash.cloudflare.com/turnstile (con la site key).
#   CINECA_PASSWORD      → credenziale del service account fornita da CINECA.
#
# NB: cambiare ENCRYPTION_KEY dopo il primo uso rende ILLEGGIBILI i dati
# già cifrati (TOTP secret, CF in cache/certificati). Cambiare le chiavi
# JWT invalida gli access token attivi (basta un nuovo login).
# ============================================================

# ------------------------------------------------------------
# APPLICAZIONE
# ------------------------------------------------------------
NODE_ENV=production
PORT=3001

# URL del frontend (usato per CORS). Lista separata da virgole per più origini
# (es. dominio + www). MAI barra finale.
CLIENT_ORIGIN=https://tuodominio.it,https://www.tuodominio.it

# ------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payroll_gang
DB_USER=payroll_user
DB_PASSWORD=

# DB_SSL: impostare a 'false' per PostgreSQL locale (senza TLS) — default per sviluppo.
# IMPORTANTE: impostare a 'true' in produzione se il DB è remoto o esposto su rete.
# Con DB_SSL=true e PostgreSQL locale senza TLS il server non si avvia (ECONNREFUSED).
DB_SSL=false # Cambiare in 'true' in produzione

# Pool connessioni (valori di default consigliati per VPS small)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ------------------------------------------------------------
# JWT — ES256 (ECDSA P-256, asimmetrico)
#
# Genera la coppia di chiavi con questi comandi:
#
#   openssl ecparam -genkey -name prime256v1 -noout | \
#     openssl pkcs8 -topk8 -nocrypt -out /tmp/jwt_priv.pem
#   openssl ec -in /tmp/jwt_priv.pem -pubout -out /tmp/jwt_pub.pem
#
#   echo "JWT_PRIVATE_KEY_BASE64=$(base64 -w 0 /tmp/jwt_priv.pem)"
#   echo "JWT_PUBLIC_KEY_BASE64=$(base64 -w 0 /tmp/jwt_pub.pem)"
#
#   rm /tmp/jwt_priv.pem /tmp/jwt_pub.pem
# ------------------------------------------------------------
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ------------------------------------------------------------
# CRITTOGRAFIA — AES-256-GCM
# Usata per cifrare i TOTP secret nel database.
#
# Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Deve essere esattamente 64 caratteri hex (= 32 byte).
# ------------------------------------------------------------
ENCRYPTION_KEY=

# Chiave dedicata alla FIRMA dei cookie (consigliata, min 32 caratteri).
# Se assente viene usata ENCRYPTION_KEY (retrocompatibilità).
# Genera con lo stesso comando di ENCRYPTION_KEY.
COOKIE_SECRET=

# ------------------------------------------------------------
# TOTP — Google Authenticator / Authy
# ------------------------------------------------------------
TOTP_ISSUER=PayrollGangSuite
TOTP_WINDOW=1

# ------------------------------------------------------------
# RATE LIMITING
# Valori di default sicuri — modificare solo se necessario.
# ------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=300000

# Limite dedicato a POST /auth/refresh (chiamato a ogni reload/multi-tab).
# È protetto dal cookie HttpOnly (token 256-bit, brute-force infeasible),
# quindi il limite è più generoso di AUTH_RATE_LIMIT_MAX: pochi F5 non
# causano più 429 → logout apparente. Finestra: AUTH_RATE_LIMIT_WINDOW_MS.
REFRESH_RATE_LIMIT_MAX=30

# ------------------------------------------------------------
# SMTP — Email (opzionale)
# Il server si avvia anche senza questi valori, ma non può
# inviare email di attivazione utenti.
#
# Esempio iCloud: smtp.mail.me.com:587
# Esempio Gmail:  smtp.gmail.com:587
# ------------------------------------------------------------
# Host/porta del server SMTP (es. iCloud: smtp.mail.me.com — Gmail: smtp.gmail.com)
SMTP_HOST=smtp.tuoprovider.it
SMTP_PORT=587
# 'true' solo per SMTP implicito su porta 465; con 587 (STARTTLS) resta 'false'
SMTP_SECURE=false
# Utente SMTP (indirizzo di login del mittente)
SMTP_USER=utente@tuodominio.it
# SEGRETO — app-specific password del provider (MAI committare il valore reale)
SMTP_PASS=
# Mittente mostrato nelle email in uscita — "Nome <indirizzo>"
SMTP_FROM=Payroll Gang Suite <noreply@tuodominio.it>

# ------------------------------------------------------------
# CLOUDFLARE TURNSTILE (protezione bot — opzionale)
# Registrare il dominio su dash.cloudflare.com/turnstile
# Widget: managed · Appearance: invisible · Execution: execute
#
# VITE_TURNSTILE_SITE_KEY  → chiave pubblica (frontend, non segreta) — es. 0x4AAAAAAA...
# TURNSTILE_SECRET_KEY     → chiave privata (server only — MAI committare)
#
# Se assenti, la verifica CAPTCHA è saltata (utile in sviluppo locale).
# ------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ------------------------------------------------------------
# CINECA CSA-WS (integrazione riferimento cedolino — opzionale)
# Il server si avvia anche senza; le route /cineca/* rispondono 503
# finché tutte e 4 le variabili base non sono valorizzate.
# ------------------------------------------------------------
CINECA_BASE_URL=https://prod.csa-ws.cineca.it
# Tenant assegnato dall'ateneo (compare nell'URL CSA-WS) — es. nomeateneo
CINECA_TENANT=nomeateneo
# Username del service account CSA-WS — es. csaws_<utente>_prod_<ateneo>
CINECA_USER=csaws_utente_prod_nomeateneo
# SEGRETO — password del service account CSA-WS (MAI committare il valore reale)
CINECA_PASSWORD=
# Gruppi richiesti nel token CSA-WS (CSV): 'familiari'=figli (WE), 'sge'=stato giuridico (CF dip.)
CINECA_GROUPS=familiari,sge
# Codice rapportoParentela per figlio/figlia (da CSA: "FG")
PARENTELA_FIGLIO=FG

# ------------------------------------------------------------
# PROXY CINECA in Italia (opzionale)
# Necessario SOLO se il server è ospitato fuori UE: CINECA CSA-WS
# geo-blocca gli IP extra-UE. Il proxy (reverse proxy Caddy in Italia)
# inoltra a CINECA_BASE_URL e richiede l'header X-Proxy-Auth.
# Attivazione runtime: toggle "Proxy Italia per API CINECA" in
# Impostazioni → Moduli (admin). Setup completo: vedi CINECA_PROXY.md
#
# CINECA_PROXY_SECRET: stesso valore configurato nel Caddy del proxy
#   (min 32 caratteri) — genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ------------------------------------------------------------
CINECA_PROXY_URL=
CINECA_PROXY_SECRET=
