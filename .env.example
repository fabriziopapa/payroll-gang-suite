# ============================================================
# PAYROLL GANG SUITE — .env.example
# Copia questo file in .env e compila tutti i valori.
# MAI committare .env — contiene segreti di produzione.
# ============================================================

# ------------------------------------------------------------
# APPLICAZIONE
# ------------------------------------------------------------
NODE_ENV=production
PORT=3001

# URL del frontend (usato per CORS) — es. https://tuodominio.it
CLIENT_ORIGIN=https://tuodominio.it

# ------------------------------------------------------------
# DATABASE — PostgreSQL
# ------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payroll_gang
DB_USER=payroll_user
DB_PASSWORD=

# DB_SSL: impostare a 'false' per PostgreSQL locale (senza TLS) — default per sviluppo.
# IMPORTANTE: impostare a 'true' in produzione se il DB è remoto o esposto su rete.
# Con DB_SSL=true e PostgreSQL locale senza TLS il server non si avvia (ECONNREFUSED).
DB_SSL=false # Cambiare in 'true' in produzione

# Pool connessioni (valori di default consigliati per VPS small)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ------------------------------------------------------------
# JWT — ES256 (ECDSA P-256, asimmetrico)
#
# Genera la coppia di chiavi con questi comandi:
#
#   openssl ecparam -genkey -name prime256v1 -noout | \
#     openssl pkcs8 -topk8 -nocrypt -out /tmp/jwt_priv.pem
#   openssl ec -in /tmp/jwt_priv.pem -pubout -out /tmp/jwt_pub.pem
#
#   echo "JWT_PRIVATE_KEY_BASE64=$(base64 -w 0 /tmp/jwt_priv.pem)"
#   echo "JWT_PUBLIC_KEY_BASE64=$(base64 -w 0 /tmp/jwt_pub.pem)"
#
#   rm /tmp/jwt_priv.pem /tmp/jwt_pub.pem
# ------------------------------------------------------------
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ------------------------------------------------------------
# CRITTOGRAFIA — AES-256-GCM
# Usata per cifrare i TOTP secret nel database.
#
# Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Deve essere esattamente 64 caratteri hex (= 32 byte).
# ------------------------------------------------------------
ENCRYPTION_KEY=

# ------------------------------------------------------------
# TOTP — Google Authenticator / Authy
# ------------------------------------------------------------
TOTP_ISSUER=PayrollGangSuite
TOTP_WINDOW=1

# ------------------------------------------------------------
# RATE LIMITING
# Valori di default sicuri — modificare solo se necessario.
# ------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=300000

# ------------------------------------------------------------
# SMTP — Email (opzionale)
# Il server si avvia anche senza questi valori, ma non può
# inviare email di attivazione utenti.
#
# Esempio iCloud: smtp.mail.me.com:587
# Esempio Gmail:  smtp.gmail.com:587
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Payroll Gang Suite <noreply@tuodominio.it>

# ------------------------------------------------------------
# CLOUDFLARE TURNSTILE (protezione bot — opzionale)
# Registrare il dominio su dash.cloudflare.com/turnstile
# Widget: managed · Appearance: invisible · Execution: execute
#
# VITE_TURNSTILE_SITE_KEY  → chiave pubblica (frontend, non segreta)
# TURNSTILE_SECRET_KEY     → chiave privata (server only — MAI committare)
#
# Se assenti, la verifica CAPTCHA è saltata (utile in sviluppo locale).
# ------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
